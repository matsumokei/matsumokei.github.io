  {
    date: '2023-04',
    title: 'Researcher at Hitachi, Ltd. R&D',
    description: 'Yokohama Totsuka. Working on Software Supply Chain Security, DevSecOps, and Secure CI/CD Pipeline development.',
    detailUrl: HITACHI_ERA_DETAIL_URL,
    projects: hitachiProjects,
