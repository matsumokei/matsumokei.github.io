---

<Layout title="CV — Keisuke's Notes" description="Curriculum Vitae of Keisuke Matsumoto">
  <article class="post cv">
    <h1>Curriculum Vitae</h1>
    <p class="post-meta">Keisuke Matsumoto — Software Developer and Researcher</p>

    <h2>Career</h2>
    <ul class="cv-list">
      {careerItems.map((item) => (
        <li>
          <span class="cv-date">{item.date}</span>
          <strong>{item.title}</strong>
          <p>{item.description}</p>
          {item.projects && (
            <>
              <p class="cv-subheading">Projects</p>
              <ul class="cv-sublist">
                {item.projects.map((project) => (
                  <li>
                    <strong>{project.title}</strong>
                    <p class="cv-meta">{project.period}</p>
                    {project.tech && <p class="cv-meta">{project.tech}</p>}
                  </li>
                ))}
              </ul>
            </>
          )}
          {item.detailUrl && <p class="cv-meta"><a href={item.detailUrl}>details →</a></p>}
        </li>
      ))}
    </ul>

    <h2>Publications</h2>
    <ul class="cv-list">
      {publications.map((pub) => (
        <li>
          <a href={pub.url} target="_blank" rel="noopener noreferrer">{pub.title}</a>
          <p class="cv-meta">{pub.year}</p>
        </li>
      ))}
    </ul>

    <h2>Presentations (English)</h2>
    <ul class="cv-list">
      {presentationsEn.map((pres) => (
        <li>
          {pres.url
            ? <a href={pres.url} target="_blank" rel="noopener noreferrer">{pres.title}</a>
            : <strong>{pres.title}</strong>}
          <p class="cv-meta">{pres.conference} @{pres.location} ({pres.year})</p>
        </li>
      ))}
    </ul>

    <h2>Presentations (Japanese)</h2>
    <ul class="cv-list">
      {presentationsJa.map((pres) => (
        <li>
          {pres.url
            ? <a href={pres.url} target="_blank" rel="noopener noreferrer">{pres.title}</a>
            : <strong>{pres.title}</strong>}
          <p class="cv-meta">{pres.conference} @{pres.location} ({pres.year})</p>
        </li>
      ))}
    </ul>
  </article>
</Layout>
